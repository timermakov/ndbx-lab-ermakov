					"name": "List Event Reviews",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/events/{{event_id}}/reviews?limit=10&offset=0",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"events",
								"{{event_id}}",
								"reviews"
							],
							"query": [
								{
									"key": "limit",
