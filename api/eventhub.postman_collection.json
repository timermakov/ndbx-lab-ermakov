							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "X-Session-Id={{session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"comment\": \"Great event\",\n  \"rating\": 5\n}"
