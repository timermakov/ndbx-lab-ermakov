							}
						}
					]
				},
				{
					"name": "List Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/events?include=reactions,reviews&limit=10&offset=0",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"events"
							],
							"query": [
								{
									"key": "include",
									"value": "reactions,reviews"
								},
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "offset",
									"value": "0"
								}
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"if (json && Array.isArray(json.events) && json.events.length > 0 && json.events[0].id) {",
									"  pm.collectionVariables.set('event_id', json.events[0].id);",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Get Event By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/events/{{event_id}}?include=reactions,reviews",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"events",
								"{{event_id}}"
							],
							"query": [
								{
									"key": "include",
									"value": "reactions,reviews"
								}
							]
						}
					}
				},
				{
					"name": "Patch Event",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "X-Session-Id={{session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"category\": \"meetup\",\n  \"price\": 500,\n  \"city\": \"Saint Petersburg\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/events/{{event_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"events",
								"{{event_id}}"
							]
						}
					}
				},
				{
